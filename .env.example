# 光影折射服务端环境变量示例
# 本地调试可复制为 .env 使用
# 抖音云开发环境请在控制台配置，不要提交真实密钥

NODE_ENV=development
DOUYIN_CLOUD=false
PORT=3000

DOUYIN_APP_ID=ttd4a0a21d4ac66d7702
DOUYIN_APP_SECRET=d00428a01fb925f3ac1529741d3924fdb4062e1b
DOUYIN_PAY_SALT=your_pay_salt
JWT_SECRET=replace_with_a_random_secret_at_least_32_chars

# 本地默认可留空，服务会回落到 ./database.sqlite
# 抖音云建议配置为 /data/database.sqlite
DB_PATH=

# 如需改静态资源目录，可显式指定
# PUBLIC_DIR=/opt/application/public
